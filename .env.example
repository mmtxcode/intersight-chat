# Ollama OpenAI-compatible endpoint
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# Ollama tags endpoint (used to discover available models)
OLLAMA_TAGS_URL=http://localhost:11434/api/tags

# Intersight API base URL (override only for non-SaaS / appliance deployments)
INTERSIGHT_BASE_URL=https://intersight.com

# Path to the built MCP server entry point. Leave default unless you move things.
MCP_SERVER_CMD=node
MCP_SERVER_ARGS=mcp-server/dist/index.js

# Host port that the bundled Ollama container publishes to. Change this if
# port 11434 is already taken on the host (e.g. Ollama running natively).
# Compose-only setting — ignored by the local-Python run path.
OLLAMA_HOST_PORT=11434
